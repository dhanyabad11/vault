{
  "name": "distributed-payment-wallet",
  "version": "0.1.0",
  "description": "Distributed payment wallet — Phase 1: single-service wallet + ledger correctness",
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "ts-node src/main.ts",
    "start:dev": "ts-node-dev --respawn src/main.ts",
    "migrate": "ts-node src/database/migrate.ts",
    "db:up": "docker compose up -d db && node -e \"process.exit(0)\"",
    "db:down": "docker compose down",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-express": "^10.4.4",
    "dotenv": "^16.4.5",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.11.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
